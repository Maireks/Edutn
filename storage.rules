rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ─── PDF الدروس ─────────────────────────────
    // أي مستخدم مصادق عليه يرفع، الكل يقرأ
    match /lessons/{subjectId}/{fileName} {
      allow read:  if true;
      allow write: if request.auth != null
                   && request.resource.size < 50 * 1024 * 1024   // 50 MB حد أقصى
                   && request.resource.contentType == 'application/pdf';
    }

    // ─── صور التطبيق (للمستقبل) ─────────────────
    match /images/{imageId} {
      allow read:  if true;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024    // 5 MB حد أقصى
                   && request.resource.contentType.matches('image/.*');
    }

    // ─── حظر الباقي ─────────────────────────────
    match /{allPaths=**} {
      allow read:  if true;
      allow write: if false;
    }
  }
}
